{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "User profile picture URL" },
        "role": { "type": "string", "enum": ["admin", "analyst"], "description": "User role in the system" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "ISO timestamp of last login" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "Individual user profile documents."
    }
  }
}
